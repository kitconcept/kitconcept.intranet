        "is_editable": false,
        "modification_date": "2026-06-12T11:20:00+00:00",
        "text": {
          "data": "Stimmt, Eva. Vielleicht wird in einer n\u00e4chsten Phase dann der Roll-out beschrieben. W\u00e4re gut, mehr Transparenz beim Zeitplan zu haben.",
          "mime-type": "text/plain"
        },
