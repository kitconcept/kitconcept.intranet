        "author_username": "e.roth",
        "can_reply": false,
        "comment_id": "1781261705149707",
        "creation_date": "2026-06-12T10:55:05+00:00",
        "in_reply_to": null,
        "is_deletable": true,
        "is_editable": false,
        "modification_date": "2026-06-12T10:55:05+00:00",
        "text": {
          "data": "\u201eWenn ZTS mit lokalen Partnern arbeitet, kann echtes Know-how aufgebaut werden\u201c \u2013 genau das ist f\u00fcr mich der Schl\u00fcssel bei solchen Projekten.",
          "mime-type": "text/plain"
        },
        "user_notification": null
      },
      {
        "@id": "/aktuelles/zts-erhalt-eu-forderung-fur-wasserstoff-forschungsprojekt/@comments/1781262170309027",
