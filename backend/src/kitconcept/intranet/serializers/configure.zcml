<configure
    xmlns="http://namespaces.zope.org/zope"
    i18n_domain="kitconcept.intranet"
    >

  <utility
      factory=".summary.JSONSummarySerializerMetadata"
      name="kitconcept.intranet.summary_serializer_metadata"
      />

  <adapter factory=".vocab.SerializeTermWithUrlToJson" />
  <adapter factory=".event.EventSerializer" />
  <adapter factory=".person.PersonSerializer" />

</configure>
