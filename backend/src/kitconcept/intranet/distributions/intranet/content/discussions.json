        "author_name": "David Schmidt",
        "author_username": "d.schmidt",
        "can_reply": false,
        "comment_id": "1781258700194901",
        "creation_date": "2026-06-12T10:05:00+00:00",
        "in_reply_to": null,
        "is_deletable": true,
        "is_editable": false,
        "modification_date": "2026-06-12T10:05:00+00:00",
        "text": {
          "data": "Spannend finde ich die regionale Verankerung \u2013 wenn ZTS mit lokalen Partnern arbeitet, kann echtes Know-how auch hier aufgebaut werden.",
          "mime-type": "text/plain"
        },
        "user_notification": null
      },
      {
        "@id": "/aktuelles/zts-erhalt-eu-forderung-fur-wasserstoff-forschungsprojekt/@comments/1781262600151054",
        "@parent": "/aktuelles/zts-erhalt-eu-forderung-fur-wasserstoff-forschungsprojekt/@comments/1781258700194901",
